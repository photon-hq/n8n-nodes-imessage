{
	"name": "n8n-nodes-imessage",
	"version": "1.0.0",
	"description": "n8n community node for iMessage by Photon — send, receive, and automate iMessage conversations built on Spectrum",
	"license": "MIT",
	"keywords": [
		"n8n-community-node-package",
		"imessage",
		"spectrum",
		"photon",
		"n8n",
		"automation",
		"messaging",
		"macos"
	],
	"author": {
		"name": "Photon AI",
		"email": "vandit@photon.codes",
		"url": "https://photon.codes"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/photon-hq/n8n-nodes-imessage.git"
	},
	"homepage": "https://github.com/photon-hq/n8n-nodes-imessage#readme",
	"bugs": {
		"url": "https://github.com/photon-hq/n8n-nodes-imessage/issues"
	},
	"engines": {
		"node": ">=20.15.0"
	},
	"scripts": {
		"build": "n8n-node build && node scripts/bundle-spectrum.mjs",
		"dev": "n8n-node dev",
		"dev:tunnel": "node scripts/dev-with-tunnel.mjs",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist",
		"npm-shrinkwrap.json"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/PhotonSpectrumApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/PhotonIMessage/PhotonIMessage.node.js",
			"dist/nodes/PhotonIMessage/PhotonIMessageTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"esbuild": "^0.28.0",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"spectrum-ts": "^1.9.1",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
